#!/bin/bash
#
# dns-startup — boot launcher for the two DNS servers.
#
# You do NOT edit this file to configure the servers — all tuning (which servers
# run, threads, ports, drop-user, rate limits, ...) lives in ../dns.conf, the
# SAME file the Docker deployment reads. This launcher just sources it and
# starts whichever servers have *_ENABLED=true.
#
# It runs at boot via /etc/cron.d/dns-startup, which `make install` writes to
# point back at THIS file (`@reboot root <repo>/cron_scripts/dns-startup`).
# Because the cron entry points here, editing this file takes effect on the
# next boot with no reinstall.
#
# The script is self-locating (it derives the repo path from its own location),
# so it runs unchanged on any machine, from any checkout path.

# cron's @reboot environment is minimal; give ourselves a sane PATH so setsid,
# date, etc. resolve.
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export PATH

# --- Locate the repo (no hardcoded paths) ----------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$SCRIPT_DIR/.." && pwd)"

# ===========================================================================
# Configuration — ALL tuning lives in ../dns.conf, the same file Docker uses.
# Edit which servers run and their flags there; this launcher just reads it.
# ===========================================================================
CONF="$REPO/dns.conf"
if [ -f "$CONF" ]; then
    . "$CONF"
else
    echo "dns-startup: ERROR: config not found: $CONF" >&2
    exit 1
fi

# Shared flag assembly (the SAME builder the Makefile uses for Docker).
. "$SCRIPT_DIR/dns-args.sh"

# --- Binaries ---------------------------------------------------------------
# Default: run the binaries built in-place in the repo (self-contained — just
# `make`). To run the system-installed copies instead (after a full
# `make install`), point these at /usr/local/sbin/{upstream,auth}_dns.
UPSTREAM_BIN="$REPO/upstream_dns/bin/upstream_dns"
AUTH_BIN="$REPO/auth_dns/bin/auth_dns"

# --- Logging ----------------------------------------------------------------
# Each server writes its own query log; this captures the launcher's own
# diagnostics plus the servers' startup stderr (privilege-drop notices, bind
# warnings, etc.).
LOG_DIR="$REPO/logs"
RUNLOG="$LOG_DIR/dns-startup.log"
mkdir -p "$LOG_DIR"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') dns-startup: $*" >> "$RUNLOG"; }

# launch <label> <binary> [args...]
# Starts a foreground server detached from cron's process group (setsid + &)
# so it keeps running after this launcher exits.
launch() {
    local label="$1"; shift
    local bin="$1"; shift
    if [ ! -x "$bin" ]; then
        log "ERROR: $label binary missing or not executable: $bin (did you run 'make'?)"
        return 1
    fi
    log "starting $label: $bin $*"
    setsid "$bin" "$@" >> "$RUNLOG" 2>&1 < /dev/null &
}

# Native bundled-upstream IP is loopback; flags are assembled by dns-args.sh.
# $args is intentionally unquoted: dns.conf values never contain spaces.
start_upstream() {
    local args; args="$(build_upstream_args)"
    launch "upstream_dns (recursive resolver)" "$UPSTREAM_BIN" $args
    # Give the resolver a moment to bind before the front door forwards to it.
    sleep 2
}

start_auth() {
    local args; args="$(build_auth_args 127.0.0.1)"
    launch "auth_dns (authoritative front door)" "$AUTH_BIN" $args
}

log "boot launcher running (repo=$REPO)"

# ===========================================================================
# Which servers run is set in dns.conf (the SAME file Docker reads):
#   - both true             : recursive resolver + authoritative front door
#   - only AUTH_ENABLED     : authoritative server only
#   - only UPSTREAM_ENABLED : recursive resolver only
# ===========================================================================
[ "${UPSTREAM_ENABLED:-true}" = true ] && start_upstream
[ "${AUTH_ENABLED:-true}" = true ]     && start_auth
