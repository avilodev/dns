/home/avilo/dns/logs/upstream.log {
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    create 0644 root root
    postrotate
        # Signal upstream_dns to reopen its log fd
        if [ -f /run/upstream_dns.pid ]; then
            kill -HUP $(cat /run/upstream_dns.pid) 2>/dev/null || true
        else
            pkill -HUP -x upstream_dns 2>/dev/null || true
        fi
    endscript
}
