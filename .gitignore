# Compiled binaries
auth_dns/bin/
upstream_dns/bin/

# Object files and auto-generated dependency files
auth_dns/obj/
upstream_dns/obj/

# Catch stray .o/.d files if ever compiled outside the standard obj/ directory
*.o
*.d


# Query logs (daily-rotating, can be large)
logs/

# Testing scripts and results
testing/

# Fuzzer-generated corpus and crash artifacts (harness source is tracked)
auth_dns/fuzz/corpus/
auth_dns/fuzz/artifacts/

# Optional local env for docker compose (GHCR_OWNER / DNS_TAG image selectors)
.env

# DNSSEC zone signing keys
auth_dns/config/*.pem
auth_dns/config/*.key

# Upstream trust anchor key
upstream_dns/config/*.pem
upstream_dns/config/*.key

# Editor / IDE

.vscode/
.idea/
*.swp
*.swo
*~
