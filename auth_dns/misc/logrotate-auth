/home/avilo/dns/logs/server.log {
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    create 0644 root root
    postrotate
        # Signal auth_dns to reopen its log fd
        if [ -f /run/auth_dns.pid ]; then
            kill -HUP $(cat /run/auth_dns.pid) 2>/dev/null || true
        else
            pkill -HUP -x auth_dns 2>/dev/null || true
        fi
    endscript
}
